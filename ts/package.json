{
  "name": "reinforcement-learning",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/demo.ts --bundle --format=esm --sourcemap --outfile=dist/main.js --watch --servedir=.",
    "build": "esbuild src/demo.ts --bundle --format=esm --minify --outfile=dist/main.js",
    "build:anywidget-cartpole": "esbuild src/visualizations/cartpole/anywidget.ts --bundle --format=esm --minify --outfile=../py/dist/cartpole-visualization.js",
    "build:anywidget-pong": "esbuild src/visualizations/pong-policy/anywidget.ts --bundle --format=esm --minify --outfile=../py/dist/pong-visualization.js",
    "build:anywidget-pixel-pong": "esbuild src/visualizations/pixel-pong-policy/anywidget.ts --bundle --format=esm --minify --outfile=../py/dist/pixel-pong-visualization.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "lint": "eslint src && stylelint \"*.css\"",
    "build:anywidget-minatar-breakout": "esbuild src/visualizations/minatar-breakout/anywidget.ts --bundle --format=esm --minify --outfile=../py/dist/minatar-breakout-visualization.js",
    "build:anywidget-cartpole-reinforce": "esbuild src/visualizations/cartpole/reinforce-anywidget.ts --bundle --format=esm --minify --outfile=../py/dist/cartpole-reinforce-visualization.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.1",
    "@stylistic/stylelint-plugin": "^4.0.0",
    "@types/node": "^25.2.2",
    "esbuild": "^0.24.2",
    "eslint": "^9.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "exports": {
    "./visualizations/gridworld": "./src/visualizations/gridworld/index.ts",
    "./visualizations/policy-iteration-q": "./src/visualizations/policy-iteration-q/index.ts",
    "./visualizations/policy-iteration-v": "./src/visualizations/policy-iteration-v/index.ts",
    "./visualizations/value-iteration-v": "./src/visualizations/value-iteration-v/index.ts",
    "./visualizations/value-iteration-q": "./src/visualizations/value-iteration-q/index.ts",
    "./visualizations/monte-carlo": "./src/visualizations/monte-carlo/index.ts",
    "./visualizations/cartpole": "./src/visualizations/cartpole/index.ts",
    "./visualizations/pong": "./src/visualizations/pong/index.ts",
    "./visualizations/pong-policy": "./src/visualizations/pong-policy/index.ts",
    "./visualizations/pixel-pong": "./src/visualizations/pixel-pong/index.ts",
    "./visualizations/pixel-pong-policy": "./src/visualizations/pixel-pong-policy/index.ts",
    "./visualizations/minatar-breakout": "./src/visualizations/minatar-breakout/index.ts"
  }
}
